# TheWorld 配置文件
# 复制此文件到 .env 并填入实际值

# ===========================================
# EverMemOS 配置（必须）
# ===========================================
# EverMemOS 服务地址（假设已部署）
EVERMEMOS_URL=http://localhost:1995

# ===========================================
# AI API 配置（必须）
# ===========================================

# 方案 1: OpenAI API
# 真实 AI API Key（代理服务器使用）
REAL_AI_API_KEY=sk-xxxxxxxxxxxxxxxx

# AI 服务目标地址
AI_TARGET_BASE_URL=https://api.openai.com/v1

# 或 方案 2: Anthropic API
# REAL_AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# AI_TARGET_BASE_URL=https://api.anthropic.com/v1

# 或 方案 3: 自定义 API（如 Azure OpenAI）
# REAL_AI_API_KEY=your-azure-key
# AI_TARGET_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment

# ===========================================
# EverMemOS 需要的配置
# ===========================================
# LLM API Key（EverMemOS 记忆提取使用）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# 向量化 API Key（EverMemOS 向量化使用）
VECTORIZE_API_KEY=xxxxxxxxxxxxxxxx

# ===========================================
# TheWorld 服务配置（可选）
# ===========================================
# TheWorld Server 端口（默认 3344）
# 所有服务（REST API + AI Proxy）都运行在此端口
SERVER_PORT=3344

# 数据存储路径（可选，默认 ~/.the-world）
# WORLD_DATA_DIR=/custom/path/to/data

# ===========================================
# World Scheduler 配置（可选）
# ===========================================
# 是否启用调度器（默认 true）
SCHEDULER_ENABLED=true

# 调度策略：realtime | batch | learning
SCHEDULER_STRATEGY=realtime

# 调度器 tick 间隔（毫秒）
SCHEDULER_TICK_INTERVAL=5000

# 心跳提示词模板，支持变量：{aiName} {regionName} {timestamp}
SCHEDULER_HEARTBEAT_PROMPT=You are {aiName} in region {regionName}. Perform your heartbeat check and plan next actions at {timestamp}.

# 队列持久化路径（默认 ~/.the-world/scheduler-queue.json）
# SCHEDULER_PERSISTENCE_PATH=/custom/path/scheduler-queue.json

# ===========================================
# Memory Recall 配置（可选）
# ===========================================
# 是否启用记忆召回（默认 true）
MEMORY_RECALL_ENABLED=true

# 记忆召回数量（默认 10）
MEMORY_RECALL_TOP_K=10

# 单条记忆最大字符数（默认 500）
MEMORY_RECALL_MAX_CHARS=500

# ===========================================
# 完整示例配置
# ===========================================

# EverMemOS
EVERMEMOS_URL=http://localhost:1995

# OpenAI API
REAL_AI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx
AI_TARGET_BASE_URL=https://api.openai.com/v1

# EverMemOS 配置
LLM_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx
VECTORIZE_API_KEY=vz-xxxxxxxxxxxxxxxxxxxxx

# 服务端口（HTTP Server + AI Proxy）
SERVER_PORT=3344
